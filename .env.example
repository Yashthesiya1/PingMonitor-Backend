# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pingmonitor

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=PingMonitor
APP_URL=https://ping.yashai.me
API_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000","https://ping.yashai.me"]

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=PingMonitor <noreply@ping.yashai.me>

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
